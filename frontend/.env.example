# ── Backend proxy ─────────────────────────────────────────────────────────────
# Base URL the Next.js API proxy routes forward to.
# Default: http://127.0.0.1:8000 (local dev).
BACKEND_API_BASE_URL=http://127.0.0.1:8000

# ── Auth credentials (server-side only — never use NEXT_PUBLIC_ here) ─────────
# These are validated inside /api/auth/login and never sent to the browser.
AUTH_USERNAME=
AUTH_PASSWORD=

# ── Session signing ────────────────────────────────────────────────────────────
# Secret used to sign the httpOnly session cookie.
# Change this in production — anyone with this value can forge a session token.
# SESSION_SECRET=change-me-in-production

# ── Public demo hint (safe to expose) ─────────────────────────────────────────
# Shown on the login screen so reviewers know the demo username.
# The password is intentionally not exposed here.
NEXT_PUBLIC_AUTH_DEMO_USER=
